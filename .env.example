# ---------------------------------------------------------------------------
# Camp Planner configuration. Copy to `.env` and adjust.
# ---------------------------------------------------------------------------

# Flask
FLASK_APP=wsgi.py
FLASK_ENV=development
SECRET_KEY=change-me-in-production

# --- Database selection ----------------------------------------------------
# Either set DATABASE_URL directly (takes precedence) ...
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/camp_planner
#
# ... or pick a backend and let the app assemble the URL from the parts below.
# DB_BACKEND is one of: sqlite | postgresql | mysql
DB_BACKEND=sqlite

# Used when DB_BACKEND=sqlite (relative paths are resolved against the instance dir)
SQLITE_PATH=camp_planner.sqlite

# Used when DB_BACKEND=postgresql or mysql
DB_HOST=localhost
DB_PORT=
DB_NAME=camp_planner
DB_USER=camp
DB_PASSWORD=

# Optional prefix on every table name, so the schema can share a database with
# other apps (e.g. the KSP web). Empty = no prefix. Read at import time, so it
# must match between migration generation and runtime. Example: cp_
DB_TABLE_PREFIX=

# --- Google Calendar sync (optional) ---
# Enables two-way sync of a camp's timeline with a Google calendar. See
# docs/google_calendar_setup.md. Leave unset to disable and hide the feature
# entirely. Value is either a path to the service-account JSON key file…
# GOOGLE_SERVICE_ACCOUNT_JSON=/etc/camp-planner/service-account.json
# …or the JSON contents inline (handy for container/secret stores):
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account", ...}
